# Copy to .env.local and fill in from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Only needed to run scripts/seed-sanity.mjs once (create a token with
# Editor rights in sanity.io manage -> API -> Tokens). Do not commit.
SANITY_WRITE_TOKEN=
